# Application
ENVIRONMENT=development
LOG_LEVEL=debug
API_V1_STR=/api/v1

# Database (Supabase PostgreSQL + pgvector)
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/hiremind
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication (Clerk)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# AI & APIs
OPENAI_API_KEY=your_openai_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key

# GitHub Integration
GITHUB_API_KEY=your_github_personal_access_token

# Google Services (Phase 11)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_CALENDAR_API_KEY=
GOOGLE_DRIVE_API_KEY=

# Email Services (Phase 11)
EMAIL_API_KEY=

# Storage
SUPABASE_STORAGE_BUCKET=hiremind-uploads

# Security
JWT_SECRET=a_strong_random_secret_at_least_32_chars
